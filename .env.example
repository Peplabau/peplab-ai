# -----------------------------------------------------------------------------
# PEPLAB — client environment variables
#
# 1. Copy this file to `.env` (git-ignored) and fill in real values.
# 2. Set the same variables in Vercel → Project Settings → Environment Variables
#    for every environment you deploy to (Production, Preview, Development).
#
# Reminder: anything prefixed VITE_ is EMBEDDED IN THE CLIENT BUNDLE and
# visible to anyone who inspects the built JS. Never put a real secret behind
# a VITE_ variable — real secrets belong in Supabase Edge Function secrets
# (server-side), and the client should call the edge function.
# -----------------------------------------------------------------------------

# --- Supabase (required) ------------------------------------------------------
# These are safe to publish; the anon key has "role":"anon" baked in and is
# protected by Row Level Security on the DB. The service_role key must NEVER
# appear in this file.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Site URLs ----------------------------------------------------------------
# Canonical public URL (used in SEO, sitemaps, email links).
VITE_SITE_URL=https://peplab.com.au
# Optional override for landing-page absolute URLs (defaults to origin/landing).
# VITE_LANDING_SITE_URL=https://peplab.com.au/landing
# Optional override for cross-links back to the main site.
# VITE_MAIN_SITE_URL=https://peplab.com.au

# --- Cross-domain login split (peplab.com.au → peplab.ai) --------------------
# Comma-separated hostnames that should render the login-only shell instead
# of the full storefront. Leave empty (or comment out) on peplab.ai itself.
# Examples:
#   Staging test:     VITE_LOGIN_ONLY_HOSTS=staging.peplab.com.au
#   Production flip:  VITE_LOGIN_ONLY_HOSTS=peplab.com.au,www.peplab.com.au
VITE_LOGIN_ONLY_HOSTS=
# Absolute origin of the main app (where users are handed off after login).
VITE_MAIN_APP_ORIGIN=https://peplab.ai

# --- Email --------------------------------------------------------------------
# The email send path in production is the Supabase Edge Function `send-email`
# (its own RESEND_API_KEY lives in the Supabase project secrets, server-side).
# The variable below is a DEV-ONLY fallback via a Vite proxy — DO NOT set it
# in Vercel production, or the Resend key will leak into your public bundle.
# VITE_RESEND_API_KEY=
VITE_FROM_EMAIL=contact@peplab.com.au
# Set to true to render email HTML from the Supabase `email_templates` table
# instead of the hardcoded branded templates in src/lib/email.ts.
# VITE_EMAIL_USE_SUPABASE_HTML_TEMPLATES=false

# --- Australia Post (optional, integration currently commented out) ----------
# NOTE: any VITE_ variable is public. If/when you enable live AusPost calls,
# move these to a Supabase Edge Function and have the client call the function
# instead of AusPost directly.
VITE_AUSPOST_API_KEY=
VITE_AUSPOST_API_SECRET=

# --- Feature flags ------------------------------------------------------------
# First-visit welcome popup.
# VITE_ENABLE_SIGNUP_WELCOME_MODAL=true
# Blur COA PDF previews in the certificate dialog.
# VITE_COA_PDF_BLURRED=true
